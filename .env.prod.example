# Production environment variables for docker-compose.prod.yml
# Copy this file to .env.prod (or .env) before starting production stack.

# Required: Ollama endpoint used by backend
OLLAMA_BASE_URL=http://your-ollama-host:50050

# Optional: frontend build-time API base URL
# Keep empty to use same-origin /api via nginx proxy
VITE_API_BASE_URL=